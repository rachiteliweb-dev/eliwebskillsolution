// ─── Contact Form Submissions ─────────────────────────────────────────────────
model ContactSubmission {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  track     String?
  status    ContactSubmissionStatus @default(UNREAD)
  createdAt DateTime @default(now())
}

enum ContactSubmissionStatus {
  UNREAD
  READ
  REPLIED
}
