datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id               String       @id @default(uuid())
  name             String
  email            String       @unique
  password         String
  role             Role
  createdAt        DateTime     @default(now())
  courses          Course[]     @relation("TeacherCourses")
  enrollments      Enrollment[] @relation("StudentEnrollments")
  verifiedPayments Payment[]    @relation("Verifier")
}

model Course {
  id           String        @id @default(uuid())
  title        String
  description  String
  price        Int           // in cents / smallest currency unit
  thumbnailUrl String
  teacherId    String
  teacher      User          @relation("TeacherCourses", fields: [teacherId], references: [id])
  isPublished  Boolean       @default(false)
  createdAt    DateTime      @default(now())
  videos       CourseVideo[]
  enrollments  Enrollment[]
}

model CourseVideo {
  id        String   @id @default(uuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title     String
  videoUrl  String
  order     Int
  isPreview Boolean  @default(false)
}

model Enrollment {
  id        String           @id @default(uuid())
  studentId String
  student   User             @relation("StudentEnrollments", fields: [studentId], references: [id])
  courseId  String
  course    Course           @relation(fields: [courseId], references: [id])
  status    EnrollmentStatus @default(PENDING)
  createdAt DateTime         @default(now())
  payments  Payment[]

  @@unique([studentId, courseId])
}

model Payment {
  id             String        @id @default(uuid())
  enrollmentId   String
  enrollment     Enrollment    @relation(fields: [enrollmentId], references: [id])
  screenshotUrl  String
  transactionRef String
  amount         Int
  status         PaymentStatus @default(PENDING)
  verifiedById   String?
  verifiedBy     User?         @relation("Verifier", fields: [verifiedById], references: [id])
  createdAt      DateTime      @default(now())
}

model PaymentSettings {
  id             String @id @default("singleton")
  qrCodeImageUrl String
  upiId          String
  instructions   String
}

// ─── CMS: Home Page ──────────────────────────────────────────────────────────
model SiteHomePage {
  id             String @id @default("singleton")
  // Hero section
  heroEyebrow    String @default("Premium Skill Development Platform")
  heroHeadline1  String @default("Learn Skills.")
  heroHeadline2  String @default("Build a Career.")
  heroHeadline3  String @default("Grow Without Limits.")
  heroSubtext    String @default("Expert-led courses in web development, digital marketing, design & more. Preview free lessons, enroll easily, and learn at your own pace.")
  heroCta1Label  String @default("Explore Courses")
  heroCta2Label  String @default("Start for Free")
  heroSocialProofCount String @default("2,400+")
  // Skill Tracks section
  tracksHeadline String @default("Everything You Need to Dominate Online")
  tracksSubtext  String @default("Discover industry-relevant courses created by experts and designed to help you learn, grow, and achieve more.")
  features       Json?  // Array of highlight feature objects
  tracks         Json   // Array of track objects
  // Why Choose Us section
  whyHeadline    String @default("Why Students Choose EliWeb Skill Solution")
  whySubtext     String @default("We're not just another online platform — we're a community built around real skill outcomes.")
  whyItems       Json   // Array of why-us items
  // Stats section
  stats          Json   // Array of {value, label}
  // How It Works section
  stepsHeadline  String @default("How It Works")
  steps          Json   // Array of {number, title, desc}
  // Testimonials section
  testimonialsHeadline String @default("What Our Students Say")
  testimonialsSubtext  String @default("Hear what learners and people who trusted us have to say.")
  testimonials         Json   // Array of testimonial objects
  // FAQ section
  faqHeadline    String @default("Common Questions")
  faqs           Json   // Array of {q, a}
  // CTA Banner section
  ctaHeadline    String @default("Ready to Build Your Dream Career?")
  ctaSubtext     String @default("Join 2,400+ students who are already transforming their careers with EliWeb Skill Solution. Start with a free preview — no payment required.")
  ctaBtn1Label   String @default("Browse All Courses")
  ctaBtn2Label   String @default("Create Free Account")
}

// ─── CMS: About Page ─────────────────────────────────────────────────────────
model SiteAboutPage {
  id               String @id @default("singleton")
  heroHeadline     String @default("Empowering Careers Through Applied Learning")
  heroSubtext      String @default("Eliweb Skill Solution is a premium skill-development platform designed to bridge the gap between traditional education and industry demand.")
  missionTitle     String @default("Our Mission")
  missionPara1     String @default("At Eliweb Skill Solution, we believe everyone deserves access to high-quality, practical education that leads directly to professional success.")
  missionPara2     String @default("Founded with the goal of creating a premium, modern environment for skill development, Eliweb brings expert instructors, dynamic curriculum, and interactive learning environments to students worldwide.")
  brandName        String @default("Eliweb Skill Solution")
  foundedYear      String @default("Est. 2024")
  brandQuote       String @default("We don't teach. We empower. Our students learn to build, ship, and launch their careers with absolute confidence.")
  stats            Json   // Array of {label, value}
  valuesHeadline   String @default("Our Core Values")
  valuesSubtext    String @default("How we work, build, and support our community of learners every single day.")
  values           Json   // Array of {title, desc}
}

